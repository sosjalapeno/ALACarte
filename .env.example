# Host path where downloaded music should end up (your main music library folder).
# Required — docker compose will refuse to start without this set.
MUSIC_PATH=/path/to/your/music/library

# Port the web UI listens on (host side)
WEB_PORT=7373

# Secret used to encrypt Apple credentials at rest (64 hex chars = 32 bytes).
# If not set, one is generated on first run and stored in ./data/web/.secret
AMDL_SECRET_KEY=

# Optional: override the Docker network name. Defaults to "alacarte-net".
# DOCKER_NETWORK=alacarte-net

# Optional: set to "true" if you want to attach to an existing external network
# (e.g. one shared with Jellyfin/Plex). The network above must already exist.
# DOCKER_NETWORK_EXTERNAL=false
