# Host path where downloaded music should end up (your main music library folder).
# Required — docker compose will refuse to start without this set.
MUSIC_PATH=/path/to/your/music/library

# Port the web UI listens on (host side)
WEB_PORT=7373

# Secret used to encrypt Apple credentials at rest (64 hex chars = 32 bytes).
# If not set, one is generated on first run and stored in ./data/web/.secret
AMDL_SECRET_KEY=

# Restrict the web UI to the host machine only. Leave blank to publish on
# all interfaces (default; matches docker's behavior). Set to 127.0.0.1 if
# you front the app with a reverse proxy on the same host and don't want
# the UI directly reachable on your LAN.
WEB_BIND=

# Disable the built-in password gate. Only safe if you front the app with
# your own auth (reverse proxy auth, VPN, mesh network, etc.). Leave as
# false unless you really need it. When auth is enabled and no credentials
# exist yet, first-time setup also requires the one-time setup token from logs.
AUTH_DISABLED=false

# Trust proxy setting for Express. Keep "loopback" for local reverse-proxy
# setups. Use values like "1", "uniquelocal", or "true" only when you
# understand your proxy chain and forwarded headers.
TRUST_PROXY=loopback

# Optional: override the Docker network name. Defaults to "alacarte-net".
# DOCKER_NETWORK=alacarte-net

# Optional: set to "true" if you want to attach to an existing external network
# (e.g. one shared with Jellyfin/Plex). The network above must already exist.
# DOCKER_NETWORK_EXTERNAL=false

# Optional: temporary staging path used while jobs are downloading/converting.
# Default is /tmp/alacarte-staging, which keeps temp files outside your media library.
# AMDL_STAGING_PATH=/tmp/alacarte-staging

# Optional: prune stale staging job folders older than this many hours on app boot.
# AMDL_STAGING_MAX_AGE_HOURS=24
